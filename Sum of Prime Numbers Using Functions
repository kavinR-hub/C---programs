#include <stdio.h>

int isPrime(int n)
{
    int i;

    if (n < 2)
        return 0;

    for (i = 2; i < n; i++)
    {
        if (n % i == 0)
            return 0;
    }

    return 1;
}

int sumOfPrimes(int start, int end)
{
    int i, sum = 0;

    for (i = start; i <= end; i++)
    {
        if (isPrime(i))
            sum = sum + i;
    }

    return sum;
}

int main()
{
    int start, end;

    scanf("%d %d", &start, &end);

    if (start <= 0 || end <= 0 || start >= end)
    {
        printf("Invalid input");
        return 0;
    }

    printf("%d", sumOfPrimes(start, end));

    return 0;
}
