#include <stdio.h>

int main() {
    int rows, columns;
    scanf("%d", &rows);
    scanf("%d", &columns);
    
    // Write your code here to print the pattern
    for(int i=0;i<rows;i++){
        for(int j=0;j<columns;j++){
        printf("*",i,j);
        }
        printf("\n");
    }  
    return 0;
}
